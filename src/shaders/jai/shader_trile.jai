    highp vec3 fresnelSchlick(highp float cosTheta, highp vec3 F0)
    {
        return F0 + ((vec3(1.0) - F0) * pow(clamp(1.0 - cosTheta, 0.0, 1.0), 5.0));
    }

    highp float DistributionGGX(highp vec3 N, highp vec3 H, highp float roughness)
    {
        highp float _389 = roughness * roughness;
        highp float _393 = _389 * _389;
        highp float _398 = max(dot(N, H), 0.0);
        highp float _410 = ((_398 * _398) * (_393 - 1.0)) + 1.0;
        return _393 / ((3.141285419464111328125 * _410) * _410);
    }

    highp float GeometrySchlickGGX(highp float NdotV, highp float roughness)
    {
        highp float _423 = roughness + 1.0;
        highp float _429 = (_423 * _423) * 0.125;
